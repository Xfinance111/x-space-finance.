  <!-- ===== SCRIPTS ===== -->
  <script>
    // ===== IPHONE SCENE ROTATION (fade) =====
    (function() {
      const scenes = document.querySelectorAll('.iphone-scene');
      if (!scenes.length) return;
      let currentScene = 0;

      function showScene(index) {
        scenes.forEach((scene, i) => {
          scene.classList.toggle('active', i === index);
        });
      }

      showScene(0);

      setInterval(() => {
        currentScene = (currentScene + 1) % scenes.length;
        showScene(currentScene);
      }, 6000);
    })();


    // ===== ANIMATE NUMBERS ON SCENE 1 =====
    (function() {
      const balanceEl = document.getElementById('balanceValue');
      const inv1El = document.getElementById('inv1Amount');
      const inv2El = document.getElementById('inv2Amount');
      const dailyEl = document.getElementById('dailyReturn');
      const bar1 = document.getElementById('inv1Progress');
      const bar2 = document.getElementById('inv2Progress');
      const chart = document.getElementById('chartLine');

      if (!balanceEl) return;

      let balance = 24883.60;
      let inv1 = 3649;
      let inv2 = 683;
      let daily = 9.70;
      let dir = 1;
      let p1 = 66;
      let p2 = 33;

      setInterval(() => {
        const change = (Math.random() * 20 + 5) * dir;

        balance += change;
        balanceEl.textContent = '$' + balance.toFixed(2).replace(/\B(?=(\d{3})+(?!\d))/g, ',');
        balanceEl.classList.add('number-update');
        setTimeout(() => balanceEl.classList.remove('number-update'), 300);

        inv1 += change * 0.3;
        inv1El.textContent = '+$' + Math.floor(inv1).toLocaleString();
        inv1El.classList.add('number-update');
        setTimeout(() => inv1El.classList.remove('number-update'), 300);

        inv2 += change * 0.1;
        inv2El.textContent = '+$' + Math.floor(inv2).toLocaleString();
        inv2El.classList.add('number-update');
        setTimeout(() => inv2El.classList.remove('number-update'), 300);

        daily += change * 0.02;
        dailyEl.textContent = '+$' + daily.toFixed(2);
        dailyEl.classList.add('number-update');
        setTimeout(() => dailyEl.classList.remove('number-update'), 300);

        p1 += (Math.random() * 2 - 1) * 0.5;
        p1 = Math.min(95, Math.max(5, p1));
        bar1.style.width = p1 + '%';

        p2 += (Math.random() * 2 - 1) * 0.8;
        p2 = Math.min(95, Math.max(5, p2));
        bar2.style.width = p2 + '%';

        if (chart) {
          const y = 5 + Math.random() * 15;
          chart.setAttribute('d', `M0,35 Q25,25 50,18 T100,${y}`);
        }

        if (Math.random() < 0.1) dir *= -1;
      }, 4000);
    })();


    // ===== ANIMATE MONTHLY RETURNS ON SCENE 4 =====
    (function() {
      const monthEls = [1,2,3,4,5,6].map(i => document.getElementById('month' + i));
      const currentValEl = document.getElementById('currentValue');
      if (!monthEls[0]) return;

      let values = [175, 181, 187, 194, 201, 208];
      let base = 5000;
      let dir = 1;

      setInterval(() => {
        for (let i = 0; i < 6; i++) {
          const change = (Math.random() * 10 - 5) * dir;
          values[i] += change;
          values[i] = Math.max(50, Math.min(500, values[i]));
          if (monthEls[i]) {
            monthEls[i].textContent = '+$' + Math.floor(values[i]);
            monthEls[i].classList.add('number-update');
            setTimeout(() => monthEls[i].classList.remove('number-update'), 300);
          }
        }
        const total = values.reduce((a,b) => a + b, base);
        if (currentValEl) {
          currentValEl.textContent = '$' + Math.floor(total).toLocaleString();
          currentValEl.classList.add('number-update');
          setTimeout(() => currentValEl.classList.remove('number-update'), 300);
        }
        if (Math.random() < 0.1) dir *= -1;
      }, 5000);
    })();


    // ===== CALCULATOR WIDGET =====
    (function() {
      const slider = document.getElementById('calc-amount');
      const amountDisplay = document.getElementById('calc-amount-display');
      const investedEl = document.getElementById('calc-invested');
      const returnEl = document.getElementById('calc-return');
      const profitEl = document.getElementById('calc-profit');
      const buttons = document.querySelectorAll('.plan-select-btn');

      if (!slider || !buttons.length) return;

      let rate = parseFloat(buttons[0].dataset.rate) || 1;
      let duration = parseFloat(buttons[0].dataset.duration) || 1;

      function fmt(n) {
        return '$' + Math.round(n).toLocaleString('en-US');
      }

      function calc() {
        const p = parseInt(slider.value);
        const r = rate / 100;
        const n = duration;
        const total = p * Math.pow(1 + r, n);
        const profit = total - p;

        amountDisplay.textContent = fmt(p);
        investedEl.textContent = fmt(p);
        returnEl.textContent = fmt(total);
        profitEl.textContent = '+' + fmt(profit);
      }

      slider.addEventListener('input', calc);

      buttons.forEach(btn => {
        btn.addEventListener('click', function() {
          buttons.forEach(b => {
            b.classList.remove('bg-slate-900', 'text-white', 'border-slate-900');
            b.classList.add('bg-white', 'text-slate-600', 'border-slate-200');
          });
          this.classList.remove('bg-white', 'text-slate-600', 'border-slate-200');
          this.classList.add('bg-slate-900', 'text-white', 'border-slate-900');

          rate = parseFloat(this.dataset.rate);
          duration = parseFloat(this.dataset.duration);
          calc();
        });
      });

      calc();
    })();
  </script>

<script>
