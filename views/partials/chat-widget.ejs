<!-- ========================================= -->
<!-- FLOATING CHAT BUTTON                       -->
<!-- ========================================= -->
<button id="chat-toggle" class="fixed bottom-6 right-6 z-50 w-14 h-14 rounded-full bg-blue-700 text-white grid place-items-center shadow-xl shadow-blue-900/50 hover:scale-105 transition duration-300">
  <svg xmlns="http://www.w3.org/2000/svg" width="26" height="26" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M2.992 16.342a2 2 0 0 1 .094 1.167l-1.065 3.29a1 1 0 0 0 1.236 1.168l3.413-.998a2 2 0 0 1 1.099.092 10 10 0 1 0-4.777-4.719"/></svg>
  <span class="absolute -top-1 -right-1 w-3.5 h-3.5 bg-green-500 rounded-full border-2 border-white"></span>
</button>

<!-- ========================================= -->
<!-- CHAT WINDOW                               -->
<!-- ========================================= -->
<div id="chat-window" class="fixed bottom-24 right-6 z-50 w-[380px] max-w-[calc(100vw-2rem)] bg-slate-900 rounded-2xl shadow-2xl border border-slate-700 overflow-hidden hidden transition-all duration-300 flex flex-col">

  <!-- Header -->
  <div class="bg-blue-700 px-5 py-4 flex items-center justify-between shrink-0">
    <div class="flex items-center gap-3">
      <div class="w-9 h-9 rounded-full bg-white/20 flex items-center justify-center">
        <svg class="w-5 h-5 text-white" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M8 12h.01M12 12h.01M16 12h.01M21 12c0 4.418-4.03 8-9 8a9.863 9.863 0 01-4.255-.949L3 20l1.395-3.72C3.512 15.042 3 13.574 3 12c0-4.418 4.03-8 9-8s9 3.582 9 8z"/></svg>
      </div>
      <div>
        <span class="font-semibold text-white text-sm">Support</span>
        <div class="flex items-center gap-1.5">
          <span class="w-2 h-2 bg-green-400 rounded-full inline-block animate-pulse"></span>
          <span class="text-xs text-white/80">Online</span>
        </div>
      </div>
    </div>
    <button id="chat-close" class="text-white/70 hover:text-white transition">
      <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M6 18L18 6M6 6l12 12"/></svg>
    </button>
  </div>

  <!-- Messages -->
  <div id="chat-messages" class="flex-1 overflow-y-auto p-4 space-y-3 bg-slate-950 min-h-[300px] max-h-[400px]">
    <!-- Initial bot message -->
    <div class="flex items-start gap-3">
      <div class="w-8 h-8 rounded-full bg-blue-800 flex items-center justify-center flex-shrink-0">
        <svg class="w-4 h-4 text-blue-300" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M8 12h.01M12 12h.01M16 12h.01M21 12c0 4.418-4.03 8-9 8a9.863 9.863 0 01-4.255-.949L3 20l1.395-3.72C3.512 15.042 3 13.574 3 12c0-4.418 4.03-8 9-8s9 3.582 9 8z"/></svg>
      </div>
      <div class="bg-slate-800 rounded-lg px-4 py-2.5 text-sm text-slate-200 shadow-sm max-w-[85%]">
        <p class="font-medium text-white">How can we help?</p>
        <p class="text-xs text-slate-400 mt-0.5">Your inquiry is handled by our team.</p>
      </div>
    </div>

    <!-- Topic container (will be filled by JS) -->
    <div id="topic-container" class="space-y-2 mt-2"></div>

    <!-- Form container (name/email) -->
    <div id="form-container" class="hidden"></div>
  </div>

  <!-- Input area (hidden until form is submitted) -->
  <div class="border-t border-slate-700 p-3 bg-slate-900 shrink-0">
    <form id="chat-form" class="flex gap-2">
      <input type="text" id="chat-input" placeholder="Type a message..." class="flex-1 px-4 py-2 border border-slate-600 rounded-lg bg-slate-800 text-white text-sm focus:ring-2 focus:ring-blue-600 focus:border-transparent outline-none placeholder-slate-500">
      <button type="submit" class="px-4 py-2 bg-blue-700 text-white rounded-lg text-sm font-semibold hover:bg-blue-800 transition">Send</button>
    </form>
  </div>
</div>

<!-- ========================================= -->
<!-- CHAT JAVASCRIPT (full logic)              -->
<!-- ========================================= -->
<script>
  (function() {
    const toggle = document.getElementById('chat-toggle');
    const windowEl = document.getElementById('chat-window');
    const closeBtn = document.getElementById('chat-close');
    const form = document.getElementById('chat-form');
    const input = document.getElementById('chat-input');
    const messages = document.getElementById('chat-messages');
    const topicContainer = document.getElementById('topic-container');
    const formContainer = document.getElementById('form-container');

    let state = 'topics'; // 'topics' | 'form' | 'chat'
    let currentTopic = 'general';

    // Toggle chat
    toggle.addEventListener('click', () => {
      windowEl.classList.toggle('hidden');
      if (!windowEl.classList.contains('hidden') && state === 'topics') {
        renderTopics();
      }
    });
    closeBtn.addEventListener('click', () => windowEl.classList.add('hidden'));

    // Render topic buttons
    function renderTopics() {
      topicContainer.innerHTML = '';
      const topics = [
        { label: 'Investment', value: 'investment' },
        { label: 'Platform', value: 'platform' },
        { label: 'Account', value: 'account' },
        { label: 'Security', value: 'security' }
      ];
      topics.forEach(t => {
        const btn = document.createElement('button');
        btn.className = 'w-full text-left px-4 py-2.5 bg-slate-800 hover:bg-slate-700 rounded-lg border border-slate-700 text-sm text-white transition';
        btn.textContent = t.label;
        btn.dataset.value = t.value;
        btn.addEventListener('click', () => selectTopic(t.value, t.label));
        topicContainer.appendChild(btn);
      });
      document.querySelector('#chat-form').style.display = 'none';
      formContainer.classList.add('hidden');
    }

    // Select topic
    function selectTopic(value, label) {
      currentTopic = value;
      appendMessage('user', 'Topic: ' + label);
      state = 'form';
      topicContainer.innerHTML = '';
      document.querySelector('#chat-form').style.display = 'none';
      renderForm();
    }

    // Render name/email form
    function renderForm() {
      formContainer.innerHTML = '';
      formContainer.classList.remove('hidden');

      const wrapper = document.createElement('div');
      wrapper.className = 'bg-slate-800 rounded-lg p-4 space-y-3';
      wrapper.innerHTML = `
        <p class="text-sm font-medium text-white">Your details</p>
        <div>
          <label class="block text-xs text-slate-400 mb-1">Full name *</label>
          <input type="text" id="chat-name" placeholder="Enter your name" class="w-full px-3 py-2 border border-slate-600 rounded-lg bg-slate-900 text-white text-sm focus:ring-2 focus:ring-blue-600 focus:border-transparent outline-none placeholder-slate-500">
        </div>
        <div>
          <label class="block text-xs text-slate-400 mb-1">Email *</label>
          <input type="email" id="chat-email" placeholder="Enter your email" class="w-full px-3 py-2 border border-slate-600 rounded-lg bg-slate-900 text-white text-sm focus:ring-2 focus:ring-blue-600 focus:border-transparent outline-none placeholder-slate-500">
        </div>
        <button id="chat-submit-details" class="w-full py-2 bg-blue-700 text-white text-sm font-semibold rounded-lg hover:bg-blue-800 transition">Submit</button>
      `;
      formContainer.appendChild(wrapper);

      document.getElementById('chat-submit-details').addEventListener('click', submitDetails);
      document.getElementById('chat-name').addEventListener('keydown', (e) => { if (e.key === 'Enter') submitDetails(); });
      document.getElementById('chat-email').addEventListener('keydown', (e) => { if (e.key === 'Enter') submitDetails(); });
    }

    // Submit name/email
    function submitDetails() {
      const name = document.getElementById('chat-name').value.trim();
      const email = document.getElementById('chat-email').value.trim();
      if (!name || !email) {
        alert('Please fill in both fields.');
        return;
      }

      // Send to backend
      fetch('/api/chat/send', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({
          name: name,
          email: email,
          topic: currentTopic,
          message: 'Name: ' + name + ', Email: ' + email + ', Topic: ' + currentTopic,
          sender: 'user'
        })
      })
      .then(res => res.json())
      .then(data => {
        if (data.success) {
          appendMessage('user', 'Name: ' + name + '\nEmail: ' + email);
          formContainer.classList.add('hidden');
          document.querySelector('#chat-form').style.display = 'flex';
          state = 'chat';
          setTimeout(() => {
            appendMessage('bot', data.reply || 'Thanks! Our team will respond shortly.');
          }, 600);
        } else {
          alert('Error: ' + (data.error || 'Unknown error'));
        }
      })
      .catch(err => {
        console.error('Error:', err);
        alert('Failed to send. Please try again.');
      });
    }

    // Append message
    function appendMessage(sender, text) {
      const div = document.createElement('div');
      div.className = 'flex items-start gap-3 ' + (sender === 'user' ? 'justify-end' : '');

      if (sender === 'bot') {
        div.innerHTML = `
          <div class="w-8 h-8 rounded-full bg-blue-800 flex items-center justify-center flex-shrink-0">
            <svg class="w-4 h-4 text-blue-300" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M8 12h.01M12 12h.01M16 12h.01M21 12c0 4.418-4.03 8-9 8a9.863 9.863 0 01-4.255-.949L3 20l1.395-3.72C3.512 15.042 3 13.574 3 12c0-4.418 4.03-8 9-8s9 3.582 9 8z"/></svg>
          </div>
          <div class="bg-slate-800 rounded-lg px-4 py-2.5 text-sm text-slate-200 shadow-sm max-w-[85%] whitespace-pre-line">${text}</div>
        `;
      } else {
        div.innerHTML = `
          <div class="bg-blue-700 text-white rounded-lg px-4 py-2.5 text-sm shadow-sm max-w-[85%] whitespace-pre-line">${text}</div>
          <div class="w-8 h-8 rounded-full bg-blue-700 flex items-center justify-center flex-shrink-0">
            <svg class="w-4 h-4 text-white" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"/></svg>
          </div>
        `;
      }
      messages.appendChild(div);
      messages.scrollTop = messages.scrollHeight;
    }

    // Manual message send
    form.addEventListener('submit', function(e) {
      e.preventDefault();
      const msg = input.value.trim();
      if (!msg || state !== 'chat') return;

      appendMessage('user', msg);
      input.value = '';

      fetch('/api/chat/send', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({
          message: msg,
          sender: 'user',
          topic: currentTopic
        })
      })
      .then(res => res.json())
      .then(data => {
        if (data.success && data.reply) {
          setTimeout(() => appendMessage('bot', data.reply), 600);
        }
      })
      .catch(err => console.error('Error:', err));
    });

    // Hide input initially
    document.querySelector('#chat-form').style.display = 'none';

    // If chat is already open, render topics
    if (!windowEl.classList.contains('hidden')) {
      renderTopics();
    }
  })();
</script>