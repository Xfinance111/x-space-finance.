<div id="cookie-modal" class="fixed inset-0 bg-black/70 flex items-center justify-center z-50 hidden">
  <div class="bg-white dark:bg-slate-800 rounded-2xl max-w-2xl w-full mx-4 p-6 max-h-[90vh] overflow-y-auto">
    <h2 class="text-2xl font-bold text-slate-900 dark:text-white mb-4">Cookie Preferences</h2>
    <p class="text-slate-600 dark:text-slate-300 text-sm mb-6">Choose which cookie categories you'd like to allow. Essential cookies are always active as they are necessary for the site to function properly.</p>
    <div class="space-y-4">
      <!-- Essential -->
      <div class="flex items-start justify-between p-4 bg-slate-50 dark:bg-slate-700/50 rounded-lg">
        <div>
          <h3 class="font-semibold text-slate-900 dark:text-white">Essential</h3>
          <p class="text-sm text-slate-500 dark:text-slate-400">Required for basic site functionality including security, session management, and accessibility. These cannot be disabled.</p>
        </div>
        <span class="text-sm font-medium text-green-600 dark:text-green-400 bg-green-100 dark:bg-green-900/30 px-3 py-1 rounded-full">Always Active</span>
      </div>
      <!-- Analytics -->
      <div class="flex items-center justify-between p-4 bg-slate-50 dark:bg-slate-700/50 rounded-lg">
        <div>
          <h3 class="font-semibold text-slate-900 dark:text-white">Analytics</h3>
          <p class="text-sm text-slate-500 dark:text-slate-400">Help us understand how visitors interact with our site by collecting anonymous usage data. This helps us improve our services.</p>
        </div>
        <label class="relative inline-flex items-center cursor-pointer">
          <input type="checkbox" id="cookie-analytics" class="sr-only peer" checked>
          <div class="w-11 h-6 bg-slate-200 peer-focus:ring-2 peer-focus:ring-blue-300 rounded-full peer peer-checked:bg-blue-600 transition"></div>
        </label>
      </div>
      <!-- Marketing -->
      <div class="flex items-center justify-between p-4 bg-slate-50 dark:bg-slate-700/50 rounded-lg">
        <div>
          <h3 class="font-semibold text-slate-900 dark:text-white">Marketing</h3>
          <p class="text-sm text-slate-500 dark:text-slate-400">Used to deliver personalized advertisements and track the effectiveness of marketing campaigns across platforms.</p>
        </div>
        <label class="relative inline-flex items-center cursor-pointer">
          <input type="checkbox" id="cookie-marketing" class="sr-only peer" checked>
          <div class="w-11 h-6 bg-slate-200 peer-focus:ring-2 peer-focus:ring-blue-300 rounded-full peer peer-checked:bg-blue-600 transition"></div>
        </label>
      </div>
      <!-- Functional -->
      <div class="flex items-center justify-between p-4 bg-slate-50 dark:bg-slate-700/50 rounded-lg">
        <div>
          <h3 class="font-semibold text-slate-900 dark:text-white">Functional</h3>
          <p class="text-sm text-slate-500 dark:text-slate-400">Enable enhanced functionality such as live chat, video embeds, and social media integrations.</p>
        </div>
        <label class="relative inline-flex items-center cursor-pointer">
          <input type="checkbox" id="cookie-functional" class="sr-only peer" checked>
          <div class="w-11 h-6 bg-slate-200 peer-focus:ring-2 peer-focus:ring-blue-300 rounded-full peer peer-checked:bg-blue-600 transition"></div>
        </label>
      </div>
    </div>
    <div class="mt-6 flex justify-end gap-3">
      <button onclick="saveCookiePreferences()" class="px-6 py-2 bg-blue-600 text-white text-sm font-semibold rounded-lg hover:bg-blue-700 transition">Save Preferences</button>
      <button onclick="closeCookieSettings()" class="px-6 py-2 border border-slate-300 dark:border-slate-600 text-slate-700 dark:text-slate-300 text-sm font-semibold rounded-lg hover:bg-slate-100 dark:hover:bg-slate-700 transition">Close</button>
    </div>
  </div>
</div>