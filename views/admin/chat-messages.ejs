<%- include('../partials/header') %>

<div class="bg-slate-50 min-h-screen py-16">
  <div class="max-w-7xl mx-auto px-4 sm:px-6">
    <div class="bg-white rounded-2xl shadow-lg p-6 md:p-8">
      <div class="flex justify-between items-center mb-6">
        <h1 class="text-2xl font-bold text-slate-900">Chat Messages</h1>
        <span class="text-sm text-slate-500"><%= messages ? messages.length : 0 %> total</span>
      </div>

      <div class="overflow-x-auto">
        <table class="min-w-full divide-y divide-slate-200 border border-slate-200 rounded-lg">
          <thead class="bg-slate-50">
            <tr>
              <th class="px-4 py-3 text-left text-xs font-semibold text-slate-600 uppercase tracking-wider">#</th>
              <th class="px-4 py-3 text-left text-xs font-semibold text-slate-600 uppercase tracking-wider">Name</th>
              <th class="px-4 py-3 text-left text-xs font-semibold text-slate-600 uppercase tracking-wider">Email</th>
              <th class="px-4 py-3 text-left text-xs font-semibold text-slate-600 uppercase tracking-wider">Topic</th>
              <th class="px-4 py-3 text-left text-xs font-semibold text-slate-600 uppercase tracking-wider">Message</th>
              <th class="px-4 py-3 text-left text-xs font-semibold text-slate-600 uppercase tracking-wider">Sender</th>
              <th class="px-4 py-3 text-left text-xs font-semibold text-slate-600 uppercase tracking-wider">Date</th>
            </tr>
          </thead>
          <tbody class="bg-white divide-y divide-slate-200">
            <% if (messages && messages.length > 0) { %>
              <% messages.forEach(function(msg) { %>
                <tr class="hover:bg-slate-50 transition">
                  <td class="px-4 py-3 text-sm text-slate-500"><%= msg.id %></td>
                  <td class="px-4 py-3 text-sm text-slate-800"><%= msg.name || '—' %></td>
                  <td class="px-4 py-3 text-sm text-slate-800"><%= msg.email || '—' %></td>
                  <td class="px-4 py-3 text-sm">
                    <span class="inline-block px-2 py-1 rounded-full text-xs font-medium
                      <%= msg.topic === 'investment' ? 'bg-blue-100 text-blue-700' :
                          msg.topic === 'platform' ? 'bg-purple-100 text-purple-700' :
                          msg.topic === 'account' ? 'bg-green-100 text-green-700' :
                          msg.topic === 'security' ? 'bg-red-100 text-red-700' :
                          'bg-slate-100 text-slate-700' %>">
                      <%= msg.topic || 'general' %>
                    </span>
                  </td>
                  <td class="px-4 py-3 text-sm text-slate-700 max-w-xs truncate"><%= msg.message %></td>
                  <td class="px-4 py-3 text-sm">
                    <span class="inline-block px-2 py-1 rounded-full text-xs font-medium
                      <%= msg.sender === 'bot' ? 'bg-emerald-100 text-emerald-700' : 'bg-blue-100 text-blue-700' %>">
                      <%= msg.sender || 'user' %>
                    </span>
                  </td>
                  <td class="px-4 py-3 text-sm text-slate-500"><%= new Date(msg.created_at).toLocaleString() %></td>
                </tr>
              <% }); %>
            <% } else { %>
              <tr>
                <td colspan="7" class="px-4 py-8 text-center text-slate-400">No messages yet.</td>
              </tr>
            <% } %>
          </tbody>
        </table>
      </div>
    </div>
  </div>
</div>

<%- include('../partials/footer') %>