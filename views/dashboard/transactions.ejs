<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Transactions - XSpaceFinance</title>
  <script src="https://cdn.tailwindcss.com"></script>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet">
  <style>
    body { font-family: 'Inter', sans-serif; background: #f1f5f9; }
    .sidebar-link { display: flex; align-items: center; gap: 12px; padding: 10px 12px; border-radius: 12px; font-size: 14px; font-weight: 500; transition: all 0.2s; color: #64748b; }
    .sidebar-link:hover { background: #f1f5f9; color: #1e293b; }
    .sidebar-link.active { background: #e0f2fe; color: #0284c7; }
    .sidebar-icon { width: 20px; height: 20px; }
    .sidebar-section-label { font-size: 11px; font-weight: 600; text-transform: uppercase; letter-spacing: 0.5px; color: #94a3b8; margin-bottom: 8px; padding-left: 12px; }
    .topbar { background: white; border-bottom: 1px solid #e2e8f0; padding: 12px 24px; display: flex; align-items: center; justify-content: space-between; position: sticky; top: 0; z-index: 40; }
    .tx-item { transition: background 0.15s ease; }
    .tx-item:hover { background: #f8fafc; }
  </style>
</head>
<body>

<div class="flex">
  <%- include('../partials/complete-sidebar') %>

  <div class="flex-1 lg:ml-64">
    <%- include('../partials/topbar') %>

    <div class="p-6">
      <div class="bg-white rounded-xl border border-slate-200 overflow-hidden">
        <div class="px-6 py-4 border-b border-slate-200 flex justify-between items-center">
          <div>
            <h2 class="font-semibold text-slate-800">Transaction History</h2>
            <p class="text-xs text-slate-500 mt-0.5">All your deposits, withdrawals, and investment transactions</p>
          </div>
          <span class="text-xs text-slate-400"><%= transactions ? transactions.length : 0 %> transactions</span>
        </div>

        <% if (transactions && transactions.length > 0) { %>
          <div class="divide-y divide-slate-100">
            <% transactions.forEach(function(tx) { %>
              <div class="tx-item px-6 py-4 flex justify-between items-center">
                <div class="flex items-center gap-4">
                  <!-- Icon based on type -->
                  <div class="w-10 h-10 rounded-full flex items-center justify-center 
                    <% if (tx.type === 'deposit') { %>bg-emerald-100<% } 
                    else if (tx.type === 'investment') { %>bg-purple-100<% } 
                    else if (tx.type === 'withdrawal') { %>bg-red-100<% } 
                    else if (tx.type === 'referral') { %>bg-blue-100<% } 
                    else { %>bg-slate-100<% } %>">
                    <% if (tx.type === 'deposit') { %>
                      <svg class="w-5 h-5 text-emerald-600" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24"><path d="M3 16.5v2.25A2.25 2.25 0 0 0 5.25 21h13.5A2.25 2.25 0 0 0 21 18.75V16.5M16.5 12 12 16.5m0 0L7.5 12m4.5 4.5V3"/></svg>
                    <% } else if (tx.type === 'investment') { %>
                      <svg class="w-5 h-5 text-purple-600" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24"><path d="M12 6v12m6-6H6"/></svg>
                    <% } else if (tx.type === 'withdrawal') { %>
                      <svg class="w-5 h-5 text-red-600" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24"><path d="M3 16.5v2.25A2.25 2.25 0 0 0 5.25 21h13.5A2.25 2.25 0 0 0 21 18.75V16.5m-13.5-9L12 3m0 0 4.5 4.5M12 3v13.5"/></svg>
                    <% } else { %>
                      <svg class="w-5 h-5 text-slate-500" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24"><path d="M12 6v6h4.5m4.5 0a9 9 0 1 1-18 0 9 9 0 0 1 18 0Z"/></svg>
                    <% } %>
                  </div>
                  <div>
                    <p class="font-medium text-slate-800 capitalize"><%= tx.type %></p>
                    <p class="text-xs text-slate-400"><%= tx.description || 'Transaction' %> · <%= new Date(tx.created_at).toLocaleDateString() %> <%= new Date(tx.created_at).toLocaleTimeString([], {hour:'2-digit', minute:'2-digit'}) %></p>
                  </div>
                </div>
                <div class="text-right">
                  <p class="font-semibold text-slate-900 <%= (tx.amount || 0) >= 0 ? 'text-emerald-600' : 'text-red-600' %>">
                    <%= (tx.amount || 0) >= 0 ? '+' : '' %><%= formatCurrency(tx.amount || 0, user?.currency) %>
                  </p>
                  <span class="text-xs text-slate-400 capitalize"><%= tx.status || 'completed' %></span>
                </div>
              </div>
            <% }); %>
          </div>
        <% } else { %>
          <div class="p-12 text-center">
            <svg class="w-16 h-16 mx-auto mb-4 text-slate-300" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24">
              <path d="M19.5 14.25v-2.625a3.375 3.375 0 0 0-3.375-3.375h-1.5A1.125 1.125 0 0 1 13.5 7.125v-1.5a3.375 3.375 0 0 0-3.375-3.375H8.25m0 12.75h7.5m-7.5 3H12M10.5 2.25H5.625c-.621 0-1.125.504-1.125 1.125v17.25c0 .621.504 1.125 1.125 1.125h12.75c.621 0 1.125-.504 1.125-1.125V11.25a9 9 0 0 0-9-9Z"/>
            </svg>
            <p class="text-slate-500">No transactions yet</p>
            <a href="/dashboard/deposits" class="inline-block mt-3 text-sm text-blue-600 hover:underline">Make your first deposit →</a>
          </div>
        <% } %>
      </div>
    </div>
  </div>
</div>

</body>
</html>