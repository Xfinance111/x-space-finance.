<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Deposits - XSpaceFinance</title>
  <script src="https://cdn.tailwindcss.com"></script>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet">
  <script src="https://cdn.jsdelivr.net/npm/qrcodejs@1.0.0/qrcode.min.js"></script>
  <style>
    body { font-family: 'Inter', sans-serif; background: #f1f5f9; }
    .sidebar-link { display: flex; align-items: center; gap: 12px; padding: 10px 12px; border-radius: 12px; font-size: 14px; font-weight: 500; transition: all 0.2s; color: #64748b; }
    .sidebar-link:hover { background: #f1f5f9; color: #1e293b; }
    .sidebar-link.active { background: #e0f2fe; color: #0284c7; }
    .sidebar-icon { width: 20px; height: 20px; }
    .sidebar-section-label { font-size: 11px; font-weight: 600; text-transform: uppercase; letter-spacing: 0.5px; color: #94a3b8; margin-bottom: 8px; padding-left: 12px; }
    .topbar { background: white; border-bottom: 1px solid #e2e8f0; padding: 12px 24px; display: flex; align-items: center; justify-content: space-between; position: sticky; top: 0; z-index: 40; }
    .deposit-card { background: white; border-radius: 20px; border: 1px solid #e2e8f0; overflow: hidden; transition: all 0.2s; }
    .deposit-card:hover { box-shadow: 0 8px 25px -6px rgba(0,0,0,0.08); }
    .crypto-option { cursor: pointer; transition: all 0.2s; border: 2px solid transparent; }
    .crypto-option:hover { border-color: #3b82f6; background: #f8fafc; }
    .crypto-option.active { border-color: #3b82f6; background: #eff6ff; }
    .form-input { width: 100%; border: 1px solid #e2e8f0; border-radius: 12px; padding: 10px 14px; font-size: 14px; transition: all 0.2s; }
    .form-input:focus { outline: none; border-color: #3b82f6; box-shadow: 0 0 0 3px rgba(59,130,246,0.1); }
    .form-label { display: block; font-size: 13px; font-weight: 500; color: #1e293b; margin-bottom: 6px; }
    .loading-spinner { display: inline-block; width: 20px; height: 20px; border: 3px solid rgba(255,255,255,0.3); border-radius: 50%; border-top-color: #fff; animation: spin 1s ease-in-out infinite; }
    @keyframes spin { to { transform: rotate(360deg); } }
    
    /* Drag & Drop Styles */
    .drop-zone {
      border: 2px dashed #e2e8f0;
      border-radius: 12px;
      padding: 30px 20px;
      text-align: center;
      cursor: pointer;
      transition: all 0.3s ease;
      background: #fafbfc;
    }
    .drop-zone:hover {
      border-color: #3b82f6;
      background: #f0f7ff;
    }
    .drop-zone.dragover {
      border-color: #3b82f6;
      background: #eff6ff;
      transform: scale(1.02);
    }
    .drop-zone .file-icon {
      font-size: 40px;
      margin-bottom: 10px;
    }
    .drop-zone .file-info {
      font-size: 14px;
      color: #64748b;
    }
    .drop-zone .file-name {
      font-weight: 600;
      color: #1e293b;
      word-break: break-all;
    }
    .drop-zone .file-size {
      font-size: 12px;
      color: #94a3b8;
    }
    .drop-zone .remove-file {
      color: #ef4444;
      cursor: pointer;
      font-weight: 600;
      margin-left: 10px;
    }
    .drop-zone .remove-file:hover {
      text-decoration: underline;
    }
    .drop-zone.has-file {
      border-color: #22c55e;
      background: #f0fdf4;
    }
    .drop-zone .browse-link {
      color: #3b82f6;
      font-weight: 500;
      text-decoration: underline;
      cursor: pointer;
    }
  </style>
</head>
<body>

<div class="flex">
  <%- include('../partials/complete-sidebar') %>

  <div class="flex-1 lg:ml-64">
    <!-- TOPBAR (partial) -->
    <%- include('../partials/topbar') %>

    <div class="p-6">
      <!-- Flash Messages -->
      <% if (messages && messages.success) { %>
        <div class="bg-green-100 border border-green-400 text-green-700 px-4 py-3 rounded-lg mb-4"><%= messages.success %></div>
      <% } %>
      <% if (messages && messages.error) { %>
        <div class="bg-red-100 border border-red-400 text-red-700 px-4 py-3 rounded-lg mb-4"><%= messages.error %></div>
      <% } %>

      <div class="grid grid-cols-1 lg:grid-cols-2 gap-6">
        <!-- LEFT COLUMN – Deposit Methods -->
        <div class="space-y-6">

          <!-- 1. Bank Transfer -->
          <div class="deposit-card">
            <div class="px-6 py-4 border-b border-slate-100 bg-slate-50/50">
              <h3 class="font-semibold text-slate-800">🏦 Bank Transfer</h3>
              <p class="text-xs text-slate-500">Currently Unavailable.</p>
            </div>
            <div class="p-6 space-y-3 text-sm">
              <div class="flex justify-between"><span class="text-slate-500">Bank</span><span class="font-medium text-slate-700">---- ----</span></div>
              <div class="flex justify-between"><span class="text-slate-500">Account Name</span><span class="font-medium text-slate-700">XSpaceFinance Ltd.</span></div>
              <div class="flex justify-between"><span class="text-slate-500">Account Number</span><span class="font-medium text-slate-700">********</span></div>
              <div class="flex justify-between"><span class="text-slate-500">Sort Code</span><span class="font-medium text-slate-700">-- -- --</span></div>
              <div class="flex justify-between"><span class="text-slate-500">SWIFT</span><span class="font-medium text-slate-700">********</span></div>
              <div class="flex justify-between"><span class="text-slate-500">IBAN</span><span class="font-medium text-slate-700">-------------</span></div>
              <div class="mt-2 p-3 bg-blue-50 rounded-lg text-xs text-blue-700">
                <span class="font-medium">📌 Notice:</span> Bank deposit services are temporarily unavailable. We apologize for the inconvenience and appreciate your patience.
              </div>
            </div>
          </div>

          <!-- 2. Gift Card -->
          <div class="deposit-card">
            <div class="px-6 py-4 border-b border-slate-100 bg-slate-50/50">
              <h3 class="font-semibold text-slate-800">🎁 Gift Card</h3>
              <p class="text-xs text-slate-500">Apple gift card – upload code or image</p>
            </div>
            <div class="p-6 space-y-3 text-sm">
              <p class="text-slate-600">Upload your gift card code or screenshot here. It will be reviewed by our team.</p>
              <div class="flex items-center gap-3">
                <button type="button" id="giftCardUploadBtn" class="px-4 py-2 bg-slate-100 hover:bg-slate-200 rounded-lg text-sm font-medium transition">Choose File</button>
                <span id="giftCardFileName" class="text-sm text-slate-500">No file selected</span>
              </div>
              <input type="file" id="giftCardFileInput" class="hidden" accept="image/*,.pdf">
            </div>
          </div>

          <!-- 3. Cryptocurrency -->
          <div class="deposit-card">
            <div class="px-6 py-4 border-b border-slate-100 bg-slate-50/50">
              <h3 class="font-semibold text-slate-800">₿ Cryptocurrency</h3>
              <p class="text-xs text-slate-500">Choose a coin to see the deposit address</p>
            </div>
            <div class="p-6 space-y-5">
              <!-- Crypto options – BTC, ETH, SOL only -->
              <div class="grid grid-cols-3 gap-2">
                <button type="button" class="crypto-option active p-3 rounded-xl border border-slate-200 text-center" data-coin="BTC">
                  <div class="text-2xl">₿</div>
                  <div class="font-bold text-sm text-slate-800">BTC</div>
                  <div class="text-[10px] text-slate-400">Bitcoin</div>
                </button>
                <button type="button" class="crypto-option p-3 rounded-xl border border-slate-200 text-center" data-coin="ETH">
                  <div class="text-2xl">Ξ</div>
                  <div class="font-bold text-sm text-slate-800">ETH</div>
                  <div class="text-[10px] text-slate-400">Ethereum</div>
                </button>
                <button type="button" class="crypto-option p-3 rounded-xl border border-slate-200 text-center" data-coin="SOL">
                  <div class="text-2xl">◎</div>
                  <div class="font-bold text-sm text-slate-800">SOL</div>
                  <div class="text-[10px] text-slate-400">Solana</div>
                </button>
              </div>

              <!-- Wallet address & QR -->
              <div id="cryptoInfo" class="bg-slate-50 rounded-xl p-5 border border-slate-200">
                <div class="flex flex-col items-center">
                  <div id="qrContainer" class="bg-white p-2 rounded-lg border border-slate-200"></div>
                  <div class="mt-3 w-full">
                    <p class="text-xs text-slate-500 text-center">Wallet Address</p>
                    <div class="flex items-center gap-2 mt-1">
                      <input type="text" id="walletAddress" readonly class="form-input bg-white text-xs font-mono text-slate-700 flex-1" value="bc1qtpfcvuvt2nm6dastam8rnmt1m8v7tun9aacjup">
                      <button type="button" onclick="copyAddress()" class="px-3 py-2 bg-slate-200 text-slate-700 rounded-lg text-xs hover:bg-slate-300 transition">Copy</button>
                    </div>
                  </div>
                </div>
              </div>
            </div>
          </div>
        </div>

        <!-- RIGHT COLUMN – Deposit Form -->
        <div>
          <form action="/dashboard/deposits" method="POST" enctype="multipart/form-data" class="deposit-card" id="depositForm">
            <div class="px-6 py-4 border-b border-slate-100 bg-slate-50/50">
              <h3 class="font-semibold text-slate-800">Deposit Details</h3>
              <p class="text-xs text-slate-500">Fill in the amount and attach proof</p>
            </div>
            <div class="p-6 space-y-5">
              <!-- Deposit Method Selection -->
              <div>
                <label class="form-label">Deposit Method</label>
                <select name="method" id="depositMethodSelect" class="form-input" required>
                  <option value="bank_transfer">🏦 Bank Transfer</option>
                  <option value="gift_card">🎁 Gift Card</option>
                  <option value="crypto">₿ Cryptocurrency</option>
                </select>
              </div>

              <!-- Amount -->
              <div>
                <label class="form-label">Deposit Amount ($)</label>
                <input type="number" name="amount" step="0.01" class="form-input" placeholder="Enter amount" min="1" required>
              </div>

              <!-- Gift Card Code (only for gift card) -->
              <div id="giftCardCodeField" style="display: none;">
                <label class="form-label">Gift Card Code</label>
                <input type="text" name="gift_card_code" class="form-input" placeholder="Enter gift card code">
                <p class="text-xs text-slate-400 mt-1">Enter the gift card code or upload a screenshot below.</p>
              </div>

              <!-- Gift Card File Upload -->
              <div id="giftCardUploadField" style="display: none;">
                <label class="form-label">Gift Card Proof</label>
                <div class="drop-zone" id="giftCardDropZone">
                  <div class="file-icon">🎁</div>
                  <div class="file-info">
                    <span class="browse-link" onclick="document.getElementById('giftCardFileInput2').click()">Browse files</span> or drag & drop
                  </div>
                  <div class="file-info mt-1 text-xs text-slate-400">Supported: JPG, PNG, PDF (Max 5MB)</div>
                  <div id="giftCardFileInfo" style="display: none;" class="mt-2">
                    <span class="file-name" id="giftCardFileName2"></span>
                    <span class="file-size" id="giftCardFileSize"></span>
                    <span class="remove-file" onclick="removeGiftCardFile()">✕ Remove</span>
                  </div>
                </div>
                <input type="file" name="gift_card_file" id="giftCardFileInput2" accept="image/*,.pdf" style="display: none;">
              </div>

              <!-- Payment Proof (for bank/crypto) -->
              <div id="paymentProofField">
                <label class="form-label">Payment Proof</label>
                <div class="drop-zone" id="proofDropZone">
                  <div class="file-icon">📎</div>
                  <div class="file-info">
                    <span class="browse-link" onclick="document.getElementById('proofFileInput').click()">Browse files</span> or drag & drop
                  </div>
                  <div class="file-info mt-1 text-xs text-slate-400">Supported: JPG, PNG, PDF (Max 5MB)</div>
                  <div id="proofFileInfo" style="display: none;" class="mt-2">
                    <span class="file-name" id="proofFileName"></span>
                    <span class="file-size" id="proofFileSize"></span>
                    <span class="remove-file" onclick="removeProofFile()">✕ Remove</span>
                  </div>
                </div>
                <input type="file" name="proof" id="proofFileInput" accept="image/*,.pdf" style="display: none;">
              </div>

              <!-- Hidden fields for categorization -->
              <input type="hidden" name="crypto_address" id="cryptoAddressInput">
              <input type="hidden" name="deposit_type" id="depositTypeInput" value="deposit">

              <!-- Notes -->
              <div>
                <label class="form-label">Notes (Optional)</label>
                <textarea name="notes" rows="3" class="form-input" placeholder="Any additional information..."></textarea>
              </div>

              <!-- Submit -->
              <button type="submit" id="submitBtn" class="w-full py-3 bg-blue-600 hover:bg-blue-700 text-white font-semibold rounded-lg transition flex items-center justify-center gap-2">
                Submit Deposit
              </button>
            </div>
          </form>
        </div>
      </div>
    </div>
  </div>
</div>

<script>
  // ===== GIFT CARD UPLOAD =====
  const giftCardBtn = document.getElementById('giftCardUploadBtn');
  const giftCardFileInput = document.getElementById('giftCardFileInput');
  const giftCardFileName = document.getElementById('giftCardFileName');

  if (giftCardBtn) {
    giftCardBtn.addEventListener('click', () => {
      giftCardFileInput.click();
    });
  }

  if (giftCardFileInput) {
    giftCardFileInput.addEventListener('change', (e) => {
      if (e.target.files.length > 0) {
        giftCardFileName.textContent = e.target.files[0].name;
      } else {
        giftCardFileName.textContent = 'No file selected';
      }
    });
  }

  // ===== DEPOSIT METHOD TOGGLE =====
  const methodSelect = document.getElementById('depositMethodSelect');
  const giftCardCodeField = document.getElementById('giftCardCodeField');
  const giftCardUploadField = document.getElementById('giftCardUploadField');
  const paymentProofField = document.getElementById('paymentProofField');
  const depositTypeInput = document.getElementById('depositTypeInput');

  methodSelect.addEventListener('change', function() {
    const method = this.value;
    
    // Hide all special fields
    giftCardCodeField.style.display = 'none';
    giftCardUploadField.style.display = 'none';
    paymentProofField.style.display = 'block';
    
    // Show relevant fields based on method
    if (method === 'gift_card') {
      giftCardCodeField.style.display = 'block';
      giftCardUploadField.style.display = 'block';
      paymentProofField.style.display = 'none';
      depositTypeInput.value = 'giftcard'; // Set type for admin categorization
    } else {
      depositTypeInput.value = 'deposit'; // Regular deposit
    }
  });

  // ===== DRAG & DROP FOR PROOF FILE =====
  const proofDropZone = document.getElementById('proofDropZone');
  const proofFileInput = document.getElementById('proofFileInput');
  const proofFileInfo = document.getElementById('proofFileInfo');
  const proofFileName = document.getElementById('proofFileName');
  const proofFileSize = document.getElementById('proofFileSize');

  // Click to browse
  proofDropZone.addEventListener('click', (e) => {
    if (e.target.closest('.remove-file')) return;
    proofFileInput.click();
  });

  // Drag & drop events
  proofDropZone.addEventListener('dragover', (e) => {
    e.preventDefault();
    proofDropZone.classList.add('dragover');
  });

  proofDropZone.addEventListener('dragleave', (e) => {
    e.preventDefault();
    proofDropZone.classList.remove('dragover');
  });

  proofDropZone.addEventListener('drop', (e) => {
    e.preventDefault();
    proofDropZone.classList.remove('dragover');
    const files = e.dataTransfer.files;
    if (files.length > 0) {
      handleProofFile(files[0]);
    }
  });

  // File input change
  proofFileInput.addEventListener('change', (e) => {
    if (e.target.files.length > 0) {
      handleProofFile(e.target.files[0]);
    }
  });

  function handleProofFile(file) {
    // Validate file type
    const validTypes = ['image/jpeg', 'image/png', 'image/jpg', 'application/pdf'];
    if (!validTypes.includes(file.type)) {
      alert('Please upload a JPG, PNG, or PDF file.');
      proofFileInput.value = '';
      return;
    }

    // Validate file size (5MB)
    if (file.size > 5 * 1024 * 1024) {
      alert('File size must be less than 5MB.');
      proofFileInput.value = '';
      return;
    }

    proofDropZone.classList.add('has-file');
    proofFileInfo.style.display = 'block';
    proofFileName.textContent = file.name;
    proofFileSize.textContent = `(${(file.size / 1024 / 1024).toFixed(2)} MB)`;
    
    // Store file in input
    const dt = new DataTransfer();
    dt.items.add(file);
    proofFileInput.files = dt.files;
  }

  function removeProofFile() {
    proofDropZone.classList.remove('has-file');
    proofFileInfo.style.display = 'none';
    proofFileInput.value = '';
    proofFileName.textContent = '';
    proofFileSize.textContent = '';
  }

  // ===== DRAG & DROP FOR GIFT CARD FILE =====
  const giftCardDropZone = document.getElementById('giftCardDropZone');
  const giftCardFileInput2 = document.getElementById('giftCardFileInput2');
  const giftCardFileInfo = document.getElementById('giftCardFileInfo');
  const giftCardFileName2 = document.getElementById('giftCardFileName2');
  const giftCardFileSize2 = document.getElementById('giftCardFileSize');

  // Click to browse
  if (giftCardDropZone) {
    giftCardDropZone.addEventListener('click', (e) => {
      if (e.target.closest('.remove-file')) return;
      giftCardFileInput2.click();
    });
  }

  // Drag & drop events
  if (giftCardDropZone) {
    giftCardDropZone.addEventListener('dragover', (e) => {
      e.preventDefault();
      giftCardDropZone.classList.add('dragover');
    });

    giftCardDropZone.addEventListener('dragleave', (e) => {
      e.preventDefault();
      giftCardDropZone.classList.remove('dragover');
    });

    giftCardDropZone.addEventListener('drop', (e) => {
      e.preventDefault();
      giftCardDropZone.classList.remove('dragover');
      const files = e.dataTransfer.files;
      if (files.length > 0) {
        handleGiftCardFile(files[0]);
      }
    });
  }

  // File input change
  if (giftCardFileInput2) {
    giftCardFileInput2.addEventListener('change', (e) => {
      if (e.target.files.length > 0) {
        handleGiftCardFile(e.target.files[0]);
      }
    });
  }

  function handleGiftCardFile(file) {
    const validTypes = ['image/jpeg', 'image/png', 'image/jpg', 'application/pdf'];
    if (!validTypes.includes(file.type)) {
      alert('Please upload a JPG, PNG, or PDF file.');
      giftCardFileInput2.value = '';
      return;
    }

    if (file.size > 5 * 1024 * 1024) {
      alert('File size must be less than 5MB.');
      giftCardFileInput2.value = '';
      return;
    }

    giftCardDropZone.classList.add('has-file');
    giftCardFileInfo.style.display = 'block';
    giftCardFileName2.textContent = file.name;
    giftCardFileSize2.textContent = `(${(file.size / 1024 / 1024).toFixed(2)} MB)`;
    
    const dt = new DataTransfer();
    dt.items.add(file);
    giftCardFileInput2.files = dt.files;
  }

  function removeGiftCardFile() {
    giftCardDropZone.classList.remove('has-file');
    giftCardFileInfo.style.display = 'none';
    giftCardFileInput2.value = '';
    giftCardFileName2.textContent = '';
    giftCardFileSize2.textContent = '';
  }

  // ===== CRYPTO DATA & QR =====
  const cryptoData = {
    BTC: {
      address: 'bc1qtpfcvuvt2nm6dastam8rnmt1m8v7tun9aacjup',
      label: 'Bitcoin'
    },
    ETH: {
      address: '0xf9d5388984dBE9B79c717436e1f548fD58438692',
      label: 'Ethereum (ERC-20)'
    },
    SOL: {
      address: 'CVfsT2QwoJRNLrLkAvvmBEshDS2L4CrcfduYZAa5NaW6',
      label: 'Solana'
    }
  };

  let currentCoin = 'BTC';
  let qrCodeInstance = null;

  function updateCrypto(coin) {
    currentCoin = coin;
    const data = cryptoData[coin];
    if (!data) return;

    const addressInput = document.getElementById('walletAddress');
    const cryptoAddressInput = document.getElementById('cryptoAddressInput');
    addressInput.value = data.address;
    cryptoAddressInput.value = data.address;

    document.querySelectorAll('.crypto-option').forEach(btn => {
      btn.classList.toggle('active', btn.dataset.coin === coin);
    });

    const container = document.getElementById('qrContainer');
    container.innerHTML = '';
    qrCodeInstance = new QRCode(container, {
      text: data.address,
      width: 128,
      height: 128,
      colorDark: '#1e293b',
      colorLight: '#ffffff',
      correctLevel: QRCode.CorrectLevel.H
    });
  }

  document.querySelectorAll('.crypto-option').forEach(btn => {
    btn.addEventListener('click', () => {
      updateCrypto(btn.dataset.coin);
      methodSelect.value = 'crypto';
      methodSelect.dispatchEvent(new Event('change'));
    });
  });

  updateCrypto('BTC');

  function copyAddress() {
    const address = document.getElementById('walletAddress');
    address.select();
    navigator.clipboard.writeText(address.value).then(() => {
      alert('Address copied to clipboard!');
    }).catch(() => {
      document.execCommand('copy');
      alert('Address copied!');
    });
  }

  // ===== FORM SUBMISSION WITH LOADING STATE =====
  document.getElementById('depositForm').addEventListener('submit', function(e) {
    const submitBtn = document.getElementById('submitBtn');
    submitBtn.disabled = true;
    submitBtn.innerHTML = '<span class="loading-spinner"></span> Submitting...';
  });
</script>

</body>
</html>
